.scenic-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.tabs {
  display: flex;
  flex-direction: row;
  padding: 16rpx;
  background: #fff;
  gap: 12rpx;
  flex-wrap: wrap;
}

.tab {
  flex: 1;
  min-width: 22%;
  text-align: center;
  padding: 16rpx 8rpx;
  font-size: 26rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  color: #666;
}

.tab.active {
  background: #1e88e5;
  color: #fff;
}

.fav-bar {
  padding: 20rpx;
  background: #fff;
  font-size: 30rpx;
  font-weight: 600;
  color: #1e88e5;
}

.list {
  flex: 1;
  height: 0;
  padding: 16rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.06);
}

.cover {
  width: 100%;
  display: block;
  min-height: 200rpx;
  background: #e3f2fd;
}

.card-body {
  padding: 20rpx 24rpx 28rpx;
}

.name {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  color: #333;
}

.intro {
  font-size: 26rpx;
  color: #666;
  line-height: 1.55;
}

.actions {
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
}

.mini {
  border-radius: 22px !important;
  padding: 0 24rpx !important;
}

.mini.primary {
  background: #1e88e5 !important;
  color: #fff !important;
}

.mini::after {
  border: none !important;
}

.empty {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
}

.explain-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.explain-box {
  background: #fff;
  border-radius: 16rpx;
  width: 100%;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  padding: 24rpx;
}

.explain-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #1e88e5;
}

.explain-body {
  flex: 1;
  max-height: 50vh;
  font-size: 28rpx;
  line-height: 1.6;
  color: #444;
}

.btn-primary.small {
  width: 100%;
  margin-top: 20rpx;
  height: 80rpx;
  line-height: 80rpx;
}
