.page {
  padding-bottom: 40rpx;
}

.banner {
  width: 100%;
  height: 320rpx;
  position: relative;
  overflow: hidden;
}

.banner-img {
  width: 100%;
  height: 320rpx;
  display: block;
}

.banner-fallback {
  width: 100%;
  height: 320rpx;
  background: linear-gradient(135deg, #1565c0 0%, #1e88e5 45%, #42a5f5 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.banner-fallback-title {
  color: #fff;
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.banner-fallback-sub {
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
}

.intro-card {
  margin: 24rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.intro-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #1e88e5;
}

.intro-text {
  font-size: 28rpx;
  line-height: 1.65;
  color: #444;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 16rpx;
  justify-content: space-between;
}

.grid-item {
  width: 48%;
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.grid-item:active {
  opacity: 0.85;
}

.grid-emoji {
  font-size: 72rpx;
  line-height: 1;
  margin-bottom: 16rpx;
}

.grid-item text:last-child {
  font-size: 28rpx;
  color: #333;
}

.scan-tip {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  margin: 32rpx 48rpx 0;
  line-height: 1.5;
}

.mine-link {
  margin: 40rpx auto 0;
  width: 80%;
  height: 45px;
  line-height: 45px;
  text-align: center;
  color: #1e88e5;
  font-size: 28rpx;
  border: 1rpx solid #1e88e5;
  border-radius: 22px;
  background: #fff;
}

.mine-link:active {
  opacity: 0.85;
}
