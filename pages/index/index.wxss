.page {
  padding-bottom: 40rpx;
}

.banner {
  width: 100%;
  height: 380rpx;
  position: relative;
  overflow: hidden;
}

.banner-img {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.banner-gradient {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 180rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.5), transparent);
  z-index: 1;
}

.banner-caption {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 32rpx;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  text-align: right;
}

.banner-title {
  color: #fff;
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.35);
}

.banner-sub {
  color: rgba(255, 255, 255, 0.95);
  font-size: 26rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.35);
}

.banner-fallback {
  width: 100%;
  height: 380rpx;
  background: linear-gradient(135deg, #1a3329 0%, #2a4538 45%, #3d5c4e 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.banner-fallback-title {
  color: #fff;
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.banner-fallback-sub {
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
}

.intro-card {
  margin: 24rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.intro-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #2d6b5a;
}

.intro-text {
  font-size: 28rpx;
  line-height: 1.65;
  color: #444;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 16rpx;
  justify-content: space-between;
}

.grid-item {
  width: 48%;
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.grid-item:active {
  opacity: 0.85;
}

.grid-icon {
  width: 88rpx;
  height: 88rpx;
  margin-bottom: 16rpx;
  flex-shrink: 0;
}

.grid-label {
  font-size: 28rpx;
  color: #333;
}

.scan-tip {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  margin: 32rpx 48rpx 0;
  line-height: 1.5;
}

.mine-link {
  margin: 40rpx auto 0;
  width: 80%;
  height: 45px;
  line-height: 45px;
  text-align: center;
  color: #2d6b5a;
  font-size: 28rpx;
  border: 1rpx solid #2d6b5a;
  border-radius: 22px;
  background: #fff;
}

.mine-link:active {
  opacity: 0.85;
}
