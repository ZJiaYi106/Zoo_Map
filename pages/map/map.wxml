<!-- 地图导航页：园区内模拟地图（无底图版） -->
<view class="map-page">
  <view class="nav-bar {{isNavigating?'on':''}}">
    <text>{{navHint}}</text>
  </view>

  <view class="planner">
    <picker mode="selector" range="{{poiNames}}" value="{{startIndex}}" bindchange="onStartChange">
      <view class="picker">起点：{{poiNames[startIndex]}}</view>
    </picker>
    <picker mode="selector" range="{{poiNames}}" value="{{endIndex}}" bindchange="onEndChange">
      <view class="picker">终点：{{poiNames[endIndex]}}</view>
    </picker>
  </view>

  <view class="map-wrap">
    <view class="inner-map" bindtouchstart="onMapTouchStart" bindtouchmove="onMapTouchMove" bindtouchend="onMapTouchEnd">
      <view class="scene" style="{{sceneStyle}}">
        <view class="grid-bg"></view>
        <block wx:for="{{zones}}" wx:key="id">
          <view class="zone {{item.cls}}" style="{{item.style}}">
            <text class="zone-label">{{item.name}}</text>
          </view>
        </block>
        <block wx:for="{{roadSegments}}" wx:key="id">
          <view
            class="road {{item.onRoute?'on-route':''}} {{item.onRoute && isNavigating?'route-nav':''}}"
            style="{{item.style}}"
          ></view>
        </block>
        <block wx:for="{{poiList}}" wx:key="id">
          <view
            class="poi {{item.typeClass}} {{item.onRoute?'on-route':''}} {{item.onRoute && isNavigating?'route-pulse':''}} {{item.id===startId?'start':''}} {{item.id===endId?'end':''}} {{item.hidden?'is-hidden':''}}"
            style="left:{{item.x}}%;top:{{item.y}}%;"
            data-id="{{item.id}}"
            bindtap="onPoiTap"
          >
            <view class="dot"></view>
            <text class="label" wx:if="{{item.id===startId || item.id===endId || item.onRoute}}">{{item.name}}</text>
          </view>
        </block>
        <view class="user-pos" style="{{userPosStyle}}">
          <view class="user-pos-dot"></view>
          <text class="user-pos-label">您当前所在的位置</text>
        </view>
      </view>
    </view>
  </view>

  <view class="legend-box">
    <view class="legend-title">图例（点击筛选 / 选择目的地）</view>
    <view class="route-line-legend" wx:if="{{hasRoute}}">
      <view class="route-line-swatch"></view>
      <text class="route-line-legend-text">橙色粗线为规划路线；开始导航后会有呼吸灯效果</text>
    </view>
    <view class="legend-row">
      <block wx:for="{{legendItems}}" wx:key="type">
        <view class="legend-item {{activeLegendType===item.type?'on':''}}" data-type="{{item.type}}" bindtap="onLegendTap">
          <view class="legend-dot {{item.cls}}"></view>
          <text>{{item.label}}</text>
        </view>
      </block>
    </view>
    <view class="legend-targets" wx:if="{{legendPoiList.length>0}}">
      <block wx:for="{{legendPoiList}}" wx:key="id">
        <view class="legend-target" data-id="{{item.id}}" bindtap="onLegendPoiTap">{{item.name}}</view>
      </block>
    </view>
  </view>

  <view class="route-box">
    <view class="route-title">{{isNavigating?'导航中':'路线建议（模拟）'}}</view>
    <text class="route-path">{{routeText}}</text>
    <text class="route-meta">约 {{routeMeters}} 米 · 步行 {{routeMinutes}} 分钟</text>
    <view class="route-actions">
      <button class="route-btn primary" wx:if="{{!isNavigating}}" bindtap="startNavigation">开始导航</button>
      <button class="route-btn warn" wx:if="{{isNavigating}}" bindtap="stopNavigation">结束导航</button>
      <button class="route-btn" bindtap="planRoute">重新规划</button>
    </view>
  </view>

  <view class="toolbar">
    <button class="tool-btn primary" bindtap="goAiRoute">AI规划路线</button>
    <button class="tool-btn" bindtap="goFacility">设施查询</button>
  </view>

  <view class="popup" wx:if="{{showDetail}}">
    <view class="popup-inner">
      <view class="popup-title">{{currentPoi.name}}</view>
      <text class="popup-desc">{{currentPoi.intro}}</text>
      <view class="popup-actions">
        <button class="popup-btn ghost" bindtap="setStartFromCurrent">设为起点</button>
        <button class="popup-btn ghost" bindtap="setEndFromCurrent">设为终点</button>
        <button class="popup-btn" bindtap="startNavigationToCurrent">导航到这里</button>
      </view>
      <button class="popup-close" bindtap="closePopup">关闭</button>
    </view>
  </view>
</view>
