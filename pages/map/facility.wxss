.fac-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.cats {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  padding: 16rpx;
  gap: 12rpx;
  background: #fff;
}

.cat {
  flex: 1;
  min-width: 22%;
  text-align: center;
  padding: 18rpx 8rpx;
  font-size: 26rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  color: #666;
}

.cat.on {
  background: #1e88e5;
  color: #fff;
}

.list {
  flex: 1;
  height: 0;
  padding: 16rpx;
}

.row {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.info {
  flex: 1;
  padding-right: 16rpx;
}

.name {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.sub {
  font-size: 24rpx;
  color: #888;
  line-height: 1.4;
}

.nav-btn {
  width: 140rpx !important;
  height: 64rpx !important;
  line-height: 64rpx !important;
  border-radius: 32rpx !important;
  background: #1e88e5 !important;
  color: #fff !important;
  font-size: 26rpx !important;
  padding: 0 !important;
}

.nav-btn::after {
  border: none !important;
}

.empty {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
}
