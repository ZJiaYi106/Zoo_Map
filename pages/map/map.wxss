.map-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #eef2ef;
  box-sizing: border-box;
}

.nav-bar {
  margin: 14rpx 16rpx 0;
  padding: 14rpx 18rpx;
  font-size: 24rpx;
  border-radius: 12rpx;
  color: #38534a;
  background: #dfeee8;
}

.nav-bar.on {
  color: #fff;
  background: linear-gradient(90deg, #2d6b5a, #3f8a73);
}

.planner {
  display: flex;
  gap: 12rpx;
  padding: 16rpx;
}

.picker {
  background: #fff;
  border: 1rpx solid #d7e4df;
  color: #2d6b5a;
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  font-size: 25rpx;
}

.inner-map {
  margin: 0 16rpx;
  position: relative;
  border-radius: 18rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #eef5f2, #e5efe9);
  border: 1rpx solid #d8e8e2;
  height: 0;
  padding-top: 100%;
}

.map-wrap {
  position: relative;
}

.scene {
  position: absolute;
  inset: 0;
  transform-origin: 0 0;
}

.grid-bg {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(to right, rgba(45, 107, 90, 0.08) 1px, transparent 1px),
    linear-gradient(to bottom, rgba(45, 107, 90, 0.08) 1px, transparent 1px);
  background-size: 12.5% 12.5%;
}

.zone {
  position: absolute;
  border-radius: 20rpx;
  opacity: 0.65;
  z-index: 0;
  border: 1rpx solid rgba(45, 107, 90, 0.2);
}

.zone-beast { background: #f4d9d3; }
.zone-herb { background: #dff0d6; }
.zone-bird { background: #d8e7fa; }
.zone-service { background: #f9eec9; }

.zone-label {
  position: absolute;
  left: 10rpx;
  top: 6rpx;
  font-size: 18rpx;
  color: #587168;
}

.road {
  position: absolute;
  height: 7rpx;
  background: #b8cbc3;
  border-radius: 6rpx;
  transform-origin: 0 50%;
  z-index: 2;
}

.road.on-route {
  height: 9rpx;
  background: #2d6b5a;
  box-shadow: 0 0 8rpx rgba(45, 107, 90, 0.6);
}

.poi {
  position: absolute;
  transform: translate(-50%, -50%);
  z-index: 3;
}

.poi.is-hidden {
  opacity: 0;
  pointer-events: none;
}

.dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  background: #2d6b5a;
  margin: 0 auto 6rpx;
}

.poi.on-route .dot {
  background: #2d6b5a;
}

.poi.start .dot {
  border-color: #1e7d32;
  background: #1e7d32;
}

.poi.end .dot {
  border-color: #e65100;
  background: #e65100;
}

.poi.type-gate .dot { background: #1e88e5; }
.poi.type-service .dot { background: #7b5fb7; }
.poi.type-scenic .dot { background: #2e7d32; }
.poi.type-view .dot { background: #ef6c00; }
.poi.type-toilet .dot { background: #00838f; }
.poi.type-shop .dot { background: #6d4c41; }
.poi.type-rest .dot { background: #546e7a; }

.label {
  font-size: 18rpx;
  color: #2d3b36;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 8rpx;
  padding: 2rpx 8rpx;
  white-space: nowrap;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.user-pos {
  position: absolute;
  transform: translate(-50%, -50%);
  z-index: 6;
}

.user-pos-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #1677ff;
  border: 3rpx solid #fff;
  box-shadow: 0 0 0 8rpx rgba(22, 119, 255, 0.22);
  margin: 0 auto 8rpx;
}

.user-pos-label {
  font-size: 20rpx;
  color: #0f4ea8;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(22, 119, 255, 0.35);
  border-radius: 10rpx;
  padding: 4rpx 10rpx;
  white-space: nowrap;
}

.legend-box {
  margin: 12rpx 16rpx 0;
  background: #fff;
  border-radius: 14rpx;
  padding: 12rpx 14rpx;
}

.legend-title {
  font-size: 22rpx;
  color: #60756d;
  margin-bottom: 8rpx;
}

.legend-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 10rpx;
  border: 1rpx solid #d7e4df;
  border-radius: 999rpx;
  background: #f7fbf9;
  font-size: 22rpx;
  color: #415750;
}

.legend-item.on {
  border-color: #2d6b5a;
  background: #e8f2ee;
}

.legend-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

.legend-dot.type-all { background: #455a64; }
.legend-dot.type-gate { background: #1e88e5; }
.legend-dot.type-service { background: #7b5fb7; }
.legend-dot.type-scenic { background: #2e7d32; }
.legend-dot.type-view { background: #ef6c00; }
.legend-dot.type-toilet { background: #00838f; }
.legend-dot.type-shop { background: #6d4c41; }
.legend-dot.type-rest { background: #546e7a; }

.legend-targets {
  margin-top: 10rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.legend-target {
  font-size: 22rpx;
  color: #2d6b5a;
  border: 1rpx solid #cbe0d8;
  border-radius: 10rpx;
  padding: 6rpx 10rpx;
  background: #f6fbf9;
}


.route-box {
  margin: 14rpx 16rpx 0;
  background: #fff;
  border-radius: 14rpx;
  padding: 14rpx 18rpx;
}

.route-title {
  font-size: 24rpx;
  color: #2d6b5a;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.route-path {
  display: block;
  font-size: 23rpx;
  color: #333;
  line-height: 1.45;
}

.route-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #666;
}

.route-actions {
  margin-top: 12rpx;
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.route-btn {
  flex: 1 1 46%;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 34rpx;
  border: 1rpx solid #2d6b5a;
  color: #2d6b5a;
  background: #fff;
  font-size: 24rpx;
}

.route-btn.primary {
  color: #fff;
  background: #2d6b5a;
}

.route-btn.warn {
  color: #fff;
  background: #b75e2f;
  border-color: #b75e2f;
}

.route-btn::after {
  border: none;
}

.toolbar {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  justify-content: center;
  align-items: center;
  padding: 14rpx 12rpx 18rpx;
  gap: 12rpx;
}

.tool-btn {
  flex: 1 1 0;
  font-size: 24rpx;
  padding: 16rpx 8rpx;
  line-height: 1.3;
  background: #fff;
  color: #2d6b5a;
  border: 1rpx solid #2d6b5a;
  border-radius: 12rpx;
}

.tool-btn::after {
  border: none;
}

.tool-btn.primary {
  background: #2d6b5a;
  color: #fff;
}

.tool-btn:active {
  opacity: 0.85;
}

.popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(0, 0, 0, 0.35);
}

.popup-inner {
  background: #fff;
  border-radius: 20rpx 20rpx 0 0;
  padding: 28rpx;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d6b5a;
  margin-bottom: 16rpx;
}

.popup-desc {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
  display: block;
  margin-bottom: 18rpx;
}

.popup-actions {
  display: flex;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.popup-btn {
  flex: 1;
  height: 74rpx;
  line-height: 74rpx;
  background: #2d6b5a;
  color: #fff;
  border-radius: 36rpx;
  font-size: 26rpx;
}

.popup-btn.ghost {
  background: #fff;
  color: #2d6b5a;
  border: 1rpx solid #2d6b5a;
}

.popup-btn::after {
  border: none;
}

.popup-close {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #2d6b5a;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.popup-close::after {
  border: none;
}
