.map-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #f5f5f5;
}

.map {
  width: 100%;
  height: 80vh;
}

.toolbar {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  padding: 16rpx 12rpx 32rpx;
  gap: 12rpx;
}

.tool-btn {
  flex: 1;
  min-width: 28%;
  max-width: 32%;
  font-size: 24rpx;
  padding: 16rpx 8rpx;
  line-height: 1.3;
  background: #fff;
  color: #1e88e5;
  border: 1rpx solid #1e88e5;
  border-radius: 12rpx;
}

.tool-btn::after {
  border: none;
}

.tool-btn.primary {
  background: #1e88e5;
  color: #fff;
}

.tool-btn:active {
  opacity: 0.85;
}

.popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(0, 0, 0, 0.35);
}

.popup-inner {
  background: #fff;
  border-radius: 20rpx 20rpx 0 0;
  padding: 28rpx;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.popup-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e88e5;
  margin-bottom: 16rpx;
}

.popup-desc {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
  display: block;
  margin-bottom: 24rpx;
}

.popup-close {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #1e88e5;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.popup-close::after {
  border: none;
}
