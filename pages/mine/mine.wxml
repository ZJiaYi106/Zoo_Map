<view class="mine-page">
  <view class="user">
    <image class="avatar" src="{{user.avatarUrl}}" mode="aspectFill" binderror="onAvatarErr"></image>
    <text class="nickname">{{user.nickName}}</text>
  </view>

  <view class="menu">
    <view class="menu-item" bindtap="goFav">我的收藏</view>
    <view class="menu-item" bindtap="goHistory">历史对话</view>
    <view class="menu-item" bindtap="goAbout">关于我们</view>
    <view class="menu-item danger" bindtap="logout">退出登录</view>
  </view>

  <view class="mine-spacer"></view>
  <view class="icp-footer">
    <text class="icp-text" selectable="true">冀ICP备2025120735号</text>
  </view>
</view>
