.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  background: #f5f5f5;
}

.logo-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-emoji {
  font-size: 120rpx;
  line-height: 1;
  margin-bottom: 32rpx;
}

.logo-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1e88e5;
  margin-bottom: 12rpx;
}

.logo-sub {
  font-size: 28rpx;
  color: #666;
}

.dev-box {
  width: 90%;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.dev-title {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 600;
}

.dev-input {
  width: 100%;
  height: 72rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.dev-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-top: 16rpx;
  gap: 16rpx;
}

.dev-btn {
  flex: 1;
  font-size: 24rpx !important;
}

.dev-btn.primary {
  background: #1e88e5 !important;
  color: #fff !important;
}

.dev-hint {
  display: block;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #999;
  line-height: 1.5;
}

.login-btn {
  margin-top: 24rpx;
}

.tip {
  margin-top: 32rpx;
  font-size: 24rpx;
  color: #999;
}
