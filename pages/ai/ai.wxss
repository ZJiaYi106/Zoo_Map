.ai-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #e8f4fc;
}

.msg-scroll {
  flex: 1;
  padding: 24rpx;
  box-sizing: border-box;
}

.msg {
  max-width: 86%;
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.55;
}

.msg.user {
  margin-left: auto;
  background: #2d6b5a;
  color: #fff;
}

.msg.assistant {
  margin-right: auto;
  background: #fff;
  color: #333;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.msg-text {
  white-space: pre-wrap;
  word-break: break-all;
}

.quick-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 0 16rpx 12rpx;
  gap: 12rpx;
}

.quick-btn {
  flex: 1;
  min-width: 30%;
  font-size: 22rpx;
  line-height: 1.4;
  padding: 12rpx 8rpx;
  background: #fff;
  color: #2d6b5a;
  border: 1rpx solid #90caf9;
  border-radius: 12rpx;
}

.quick-btn::after {
  border: none;
}

.input-row {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #fff;
  border-top: 1rpx solid #e0e0e0;
}

.input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  margin-right: 16rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 140rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #2d6b5a;
  color: #fff;
  font-size: 28rpx;
  border-radius: 12rpx;
  padding: 0;
}

.send-btn::after {
  border: none;
}

.voice-row {
  padding: 12rpx 16rpx 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
}

.voice-btn {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  background: #fff;
  color: #2d6b5a;
  border: 1rpx solid #2d6b5a;
  border-radius: 36rpx;
  font-size: 26rpx;
}

.voice-btn::after {
  border: none;
}
