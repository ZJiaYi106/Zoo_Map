/** 全局样式：秦皇岛野生动物园 AI 导览 **/

page {
  background-color: #f5f5f5;
  font-family: "Microsoft YaHei", "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

/* 通用主按钮：与需求一致 */
.btn-primary {
  width: 80%;
  height: 45px;
  line-height: 45px;
  background-color: #2d6b5a;
  color: #fff;
  border-radius: 22px;
  text-align: center;
  margin: 20px auto;
  padding: 0;
  border: none;
  font-size: 30rpx;
}

.btn-primary::after {
  border: none;
}

.btn-primary-hover {
  opacity: 0.88;
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
