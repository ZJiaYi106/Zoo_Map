# 复制为 .env 后修改
APP_NAME=qhd-wildlife-ai

# 未装 MySQL 时保持 true，使用 backend/data/dev.db（推荐本地调试）
# 使用 Docker/MySQL 时改为 false，并配置下方 MYSQL_*
USE_SQLITE=true

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DB=qhd_zoo

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 微信小程序（正式环境必填；本地可设 MOCK_WX_LOGIN=true）
WX_APPID=
WX_SECRET=

# 设为 true 时 jscode2session 使用本地模拟，便于无微信后端密钥调试
MOCK_WX_LOGIN=true

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRE_MINUTES=10080

# 大模型（OpenAI 兼容 Chat Completions；填 Key 后请设 ALLOW_MOCK_LLM=false）
# 外部模型并不知道你的园区——本项目会在每次请求里注入数据库景点/设施摘要（见 project_context.py）
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# 以下为示例（是否免费以各平台当时规则为准，需自行注册拿 Key；base 末尾一般不要多写 /chat）
# Groq：LLM_API_BASE=https://api.groq.com/openai/v1  LLM_MODEL=llama-3.1-8b-instant
# DeepSeek：见 https://api.deepseek.com 文档
# 阿里云通义 / 硅基流动等：按控制台给出的「OpenAI 兼容地址」填写 LLM_API_BASE

# 无 API Key 时返回内置模拟内容，便于联调界面；接上真实 API 后改为 false
ALLOW_MOCK_LLM=true
