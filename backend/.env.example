# 复制为 .env 后修改
APP_NAME=qhd-wildlife-ai

# 未装 MySQL 时保持 true，使用 backend/data/dev.db（推荐本地调试）
# 使用 Docker/MySQL 时改为 false，并配置下方 MYSQL_*
USE_SQLITE=true

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DB=qhd_zoo

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 微信小程序（正式环境必填；本地可设 MOCK_WX_LOGIN=true）
WX_APPID=
WX_SECRET=

# 设为 true 时 jscode2session 使用本地模拟，便于无微信后端密钥调试
MOCK_WX_LOGIN=true

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRE_MINUTES=10080

# 大模型（OpenAI 兼容接口，如通义/DeepSeek/自建网关）
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# 无 API Key 时返回内置模拟内容，便于联调界面
ALLOW_MOCK_LLM=true
